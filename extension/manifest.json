{
  "manifest_version": 3,
  "name": "Recall — Save to Memory",
  "version": "2.1.0",
  "description": "Select text, ask about pages, OCR screenshots — all go into Recall memory.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "notifications",
    "tabs",
    "offscreen"
  ],
  "host_permissions": ["http://*/*", "https://*/*", "file://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["repoGraph.js", "github.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["pdf-content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
